PORT=5000
MONGODB_URI=[your MongoDB connection string here]

SMTP_USER=[your email address here]
SMTP_PASS=[your email password here]
MAIL_TO=[recipient email address here]
QUICKEMAILVERIFICATION_API_KEY=[your QuickEmailVerification API key here]
